{
  "name": "sst",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @sst/api prisma:generate",
    "db:migrate": "pnpm --filter @sst/api prisma:migrate",
    "db:seed": "pnpm --filter @sst/api prisma:seed"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
}
